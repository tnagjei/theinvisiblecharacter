{
  "name": "theinvisiblecharacter-tests",
  "version": "1.0.0",
  "description": "自动化测试套件 for TheInvisibleCharacter.live",
  "main": "index.js",
  "jest": {
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/tests/e2e/"
    ]
  },
  "scripts": {
    "build": "node scripts/build.js",
    "check:seo": "node scripts/check-seo.js",
    "check:links": "node scripts/check-links.js",
    "check:headers": "node scripts/check-headers.js",
    "check:all": "npm run build && npm run check:seo && npm run check:links && npm run check:headers",
    "test": "jest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:perf": "node tests/performance/lighthouse.js",
    "test:a11y": "node tests/accessibility/axe-test.js",
    "test:seo": "node tests/seo/seo-test.js",
    "test:security": "node tests/security/security-test.js",
    "test:all": "npm run test && npm run test:e2e && npm run test:perf && npm run test:a11y && npm run test:seo && npm run test:security",
    "report": "playwright show-report"
  },
  "keywords": [
    "testing",
    "e2e",
    "automation",
    "accessibility",
    "performance"
  ],
  "author": "测试自动化专家",
  "license": "MIT",
  "devDependencies": {
    "@axe-core/playwright": "^4.8.0",
    "@playwright/test": "^1.40.0",
    "axe-core": "^4.8.0",
    "cheerio": "^1.0.0-rc.12",
    "chrome-launcher": "^1.1.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jsdom": "^23.0.0",
    "lighthouse": "^11.4.0",
    "puppeteer": "^21.6.0",
    "tailwindcss": "^3.4.17"
  },
  "dependencies": {
    "dotenv": "^16.3.1"
  }
}
